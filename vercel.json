{
  "version": 2,
  "installCommand": "npm install --legacy-peer-deps",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "cleanUrls": false,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/site-para-:especialidade",
      "destination": "/site-para/:especialidade",
      "permanent": true
    }
  ],
  "functions": {
    "api/index.ts": {
      "includeFiles": "api/render.ts,lib/*.ts",
      "maxDuration": 25
    },
    "api/[...path].ts": {
      "includeFiles": "api/render.ts,lib/*.ts",
      "maxDuration": 25
    },
    "api/seo-robots.ts": {
      "includeFiles": "lib/*.ts",
      "maxDuration": 10
    },
    "api/seo-sitemap.ts": {
      "includeFiles": "lib/*.ts",
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/robots.txt",
      "destination": "/api/seo-robots"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/seo-sitemap"
    },
    {
      "source": "/admin",
      "destination": "/spa.html"
    },
    {
      "source": "/dashboard",
      "destination": "/spa.html"
    },
    {
      "source": "/dev",
      "destination": "/spa.html"
    },
    {
      "source": "/checkout/success",
      "destination": "/spa.html"
    },
    {
      "source": "/checkout",
      "destination": "/spa.html"
    },
    {
      "source": "/marketing-medico-primeiros-passos",
      "destination": "/spa.html"
    },
    {
      "source": "/site-para/:path*",
      "destination": "/api/site-para/:path*"
    },
    {
      "source": "/",
      "destination": "/api"
    },
    {
      "source": "/:path*",
      "destination": "/api/:path*"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Forwarded-Host",
          "value": "$host"
        },
        {
          "key": "Host",
          "value": "$host"
        },
        {
          "key": "X-Vercel-Original-Host",
          "value": "$host"
        },
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate, max-age=0, private"
        },
        {
          "key": "X-Robots-Tag",
          "value": "noindex, nofollow"
        }
      ]
    }
  ]
}